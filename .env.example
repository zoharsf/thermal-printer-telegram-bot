# Telegram
TELEGRAM_BOT_TOKEN=           # from @BotFather
ADMIN_TELEGRAM_USER_ID=       # your Telegram numeric user ID
ADMIN_DISPLAY_NAME=           # your name, shown in "ask X to add you" messages

# Printer
PRINTER_ADDRESS=              # BLE MAC address (Linux/RPi format: AA:BB:CC:DD:EE:FF)
PRINTER_ENERGY=0.75           # thermal print strength 0.0-1.0
PRINTER_FONT_SIZE=14          # font size in points

# Retry
RETRY_INTERVAL_SECONDS=600    # 10 minutes
RETRY_BACKOFF_SECONDS=1800    # 30 minutes
RETRY_BACKOFF_THRESHOLD=3     # consecutive failures before backoff

# Paths
DATA_DIR=/data
DATABASE_URL=sqlite+aiosqlite:////data/catprint.db
